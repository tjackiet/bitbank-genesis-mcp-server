        # .env.example
        PORT=3000
        LOG_DIR=./logs
        LOG_LEVEL=info

        # ── bitbank Private API（任意） ──
        # 設定すると資産残高・取引履歴などの Private API ツールが有効になります。
        # bitbank 管理画面 → API → 「参照のみ」で発行してください。
        BITBANK_API_KEY=your_api_key_here
        BITBANK_API_SECRET=your_api_secret_here